---
/**
 * Blog listing page.
 *
 * Displays all published blog posts in reverse chronological order.
 * Features client-side tag filtering and text search (title/description).
 * Minimal design inspired by vitalik.eth.limo.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Get all published posts, sorted newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all unique tags across posts
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout
  title="Blog — Rex Kirshner"
  description="Writing about Ethereum, technology, running, travel, and whatever else is on my mind."
>
  <section class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-8">Blog</h1>

      {/* Search input */}
      <div class="mb-6">
        <input
          id="blog-search"
          name="blog-search"
          type="text"
          placeholder="Search posts..."
          aria-label="Search blog posts"
          class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-300 focus:border-transparent"
        />
      </div>

      {/* Tag filter dropdown (multi-select) */}
      {allTags.length > 0 && (
        <div class="mb-8 relative" id="tag-filter-wrapper">
          <button
            id="tag-filter-toggle"
            type="button"
            aria-haspopup="listbox"
            aria-expanded="false"
            class="inline-flex items-center gap-2 px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-300 focus:border-transparent cursor-pointer"
          >
            <span id="tag-filter-label">All topics</span>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="tag-filter-dropdown"
            role="listbox"
            aria-multiselectable="true"
            class="hidden absolute left-0 top-full mt-1 bg-white border border-gray-200 rounded-lg shadow-md py-1 z-10 min-w-[180px] max-h-60 overflow-y-auto"
          >
            {allTags.map((tag) => (
              <label class="flex items-center gap-2 px-3 py-1.5 text-sm text-gray-600 hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" value={tag} class="tag-checkbox rounded border-gray-300" />
                {tag}
              </label>
            ))}
          </div>
        </div>
      )}

      {/* Post list */}
      <ul id="post-list" class="space-y-6">
        {posts.map((post) => {
          // Use UTC to prevent timezone shifts during build
          const formattedDate = post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
            timeZone: 'UTC',
          });
          return (
            <li
              class="blog-post-item"
              data-tags={post.data.tags.join(',')}
              data-title={post.data.title.toLowerCase()}
              data-description={post.data.description.toLowerCase()}
            >
              <time
                datetime={post.data.date.toISOString()}
                class="text-sm text-gray-400 tabular-nums"
              >
                {formattedDate}
              </time>
              <a
                href={`/blog/${post.id}`}
                class="block text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors mt-0.5"
              >
                {post.data.title}
              </a>
              <p class="text-sm text-gray-500 mt-1 line-clamp-2">
                {post.data.description}
              </p>
            </li>
          );
        })}
      </ul>

      {/* Empty state */}
      <p id="no-results" class="hidden text-gray-500 text-sm mt-8">
        No posts match your search.
      </p>
    </div>
  </section>

  {/* Client-side filtering and search */}
  <script>
    const searchInput = document.getElementById('blog-search') as HTMLInputElement;
    const toggleBtn = document.getElementById('tag-filter-toggle');
    const dropdown = document.getElementById('tag-filter-dropdown');
    const label = document.getElementById('tag-filter-label');
    const checkboxes = document.querySelectorAll('.tag-checkbox') as NodeListOf<HTMLInputElement>;
    const postItems = document.querySelectorAll('.blog-post-item');
    const noResults = document.getElementById('no-results');

    // Toggle dropdown
    toggleBtn?.addEventListener('click', () => {
      const isOpen = !dropdown?.classList.contains('hidden');
      dropdown?.classList.toggle('hidden');
      toggleBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
      const wrapper = document.getElementById('tag-filter-wrapper');
      if (wrapper && !wrapper.contains(e.target as Node)) {
        dropdown?.classList.add('hidden');
        toggleBtn?.setAttribute('aria-expanded', 'false');
      }
    });

    function getActiveTags(): string[] {
      return Array.from(checkboxes)
        .filter((cb) => cb.checked)
        .map((cb) => cb.value);
    }

    function updateLabel() {
      const active = getActiveTags();
      if (!label) return;
      if (active.length === 0) {
        label.textContent = 'All topics';
      } else if (active.length === 1) {
        label.textContent = active[0];
      } else {
        label.textContent = `${active.length} topics`;
      }
    }

    function filterPosts() {
      const searchTerm = searchInput?.value.toLowerCase() ?? '';
      const activeTags = getActiveTags();
      let visibleCount = 0;

      postItems.forEach((item) => {
        const el = item as HTMLElement;
        const tags = (el.dataset.tags ?? '').split(',');
        const title = el.dataset.title ?? '';
        const description = el.dataset.description ?? '';

        const matchesTag = activeTags.length === 0
          || activeTags.some((t) => tags.includes(t));
        const matchesSearch = !searchTerm
          || title.includes(searchTerm)
          || description.includes(searchTerm);

        if (matchesTag && matchesSearch) {
          el.classList.remove('hidden');
          visibleCount++;
        } else {
          el.classList.add('hidden');
        }
      });

      if (noResults) {
        noResults.classList.toggle('hidden', visibleCount > 0);
      }
    }

    searchInput?.addEventListener('input', filterPosts);
    checkboxes.forEach((cb) => {
      cb.addEventListener('change', () => {
        updateLabel();
        filterPosts();
      });
    });
  </script>
</BaseLayout>
