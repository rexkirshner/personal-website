---
/**
 * Individual blog post page.
 *
 * Renders a single blog post from the content collection at /blog/<slug>.
 * Includes: date, title, optional banner image, rendered markdown body,
 * share links (Twitter, LinkedIn, copy URL), and full SEO metadata
 * (og:type=article, article:published_time, article:tag, BlogPosting schema).
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Build canonical URL for this post
const postURL = `https://rexkirshner.com/blog/${post.id}`;

// OG image: use post banner if available, otherwise default blog OG image
// TODO: Replace default with custom blog OG image when provided
const ogImage = post.data.image || '/images/og-image.webp';

// Format date for display (e.g., "Mar 10, 2026")
// Use UTC to prevent timezone shifts during build (dates are stored as UTC midnight)
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});

// ISO dates for meta tags and schema
const isoDate = post.data.date.toISOString();
const isoUpdated = post.data.updated?.toISOString();

// Share URLs
const encodedURL = encodeURIComponent(postURL);
const encodedTitle = encodeURIComponent(post.data.title);
const twitterShareURL = `https://twitter.com/intent/tweet?url=${encodedURL}&text=${encodedTitle}`;
const linkedinShareURL = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedURL}`;
---

<BaseLayout
  title={`${post.data.title} — Rex Kirshner`}
  description={post.data.description}
  ogImage={ogImage}
  canonical={postURL}
  ogType="article"
  articleDate={isoDate}
  articleTags={post.data.tags}
>
  <!-- BreadcrumbList Schema -->
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://rexkirshner.com' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Blog', 'item': 'https://rexkirshner.com/blog' },
        { '@type': 'ListItem', 'position': 3, 'name': post.data.title, 'item': postURL },
      ],
    })}
  />

  <!-- BlogPosting Schema.org JSON-LD -->
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      'headline': post.data.title,
      'description': post.data.description,
      'datePublished': isoDate,
      ...(isoUpdated && { 'dateModified': isoUpdated }),
      'url': postURL,
      'inLanguage': 'en-US',
      'author': {
        '@type': 'Person',
        'name': 'Rex Kirshner',
        'url': 'https://rexkirshner.com',
      },
      ...(post.data.image && {
        'image': post.data.image.startsWith('http')
          ? post.data.image
          : `https://rexkirshner.com${post.data.image}`,
      }),
      'keywords': post.data.tags.join(', '),
    })}
  />

  <article class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Post header -->
      <header class="mb-10">
        <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
          <div class="flex items-center gap-4">
            <time datetime={isoDate}>{formattedDate}</time>
            <span>·</span>
            <a href="/blog" class="hover:text-gray-900 transition-colors">See all posts</a>
          </div>

          {/* Share button with dropdown */}
          <div class="relative" id="share-widget">
            <button
              id="share-toggle"
              class="inline-flex items-center gap-1.5 text-gray-400 hover:text-gray-700 transition-colors cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
              </svg>
              Share
            </button>
            <div
              id="share-dropdown"
              class="hidden absolute right-0 top-full mt-2 bg-white border border-gray-200 rounded-lg shadow-md py-1 z-10 min-w-[140px]"
            >
              <a
                href={twitterShareURL}
                target="_blank"
                rel="noopener noreferrer"
                class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors"
              >
                Twitter
              </a>
              <a
                href={linkedinShareURL}
                target="_blank"
                rel="noopener noreferrer"
                class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors"
              >
                LinkedIn
              </a>
              <button
                id="copy-url-button"
                class="block w-full text-left px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors cursor-pointer"
                data-url={postURL}
              >
                Copy Link
              </button>
            </div>
          </div>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>

        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="text-sm text-gray-500">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      {/* Banner image */}
      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.title}
          class="w-full rounded-lg mb-10"
          loading="eager"
        />
      )}

      {/* Rendered markdown body */}
      <div class="prose prose-lg max-w-none
        prose-headings:font-bold
        prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
        prose-blockquote:border-l-gray-300 prose-blockquote:text-gray-600
        prose-code:text-sm
        prose-img:rounded-lg">
        <Content />
      </div>

    </div>
  </article>

  {/* Share dropdown + copy URL script */}
  <script>
    const toggle = document.getElementById('share-toggle');
    const dropdown = document.getElementById('share-dropdown');
    const widget = document.getElementById('share-widget');

    // Toggle dropdown
    toggle?.addEventListener('click', () => {
      dropdown?.classList.toggle('hidden');
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!widget?.contains(e.target as Node)) {
        dropdown?.classList.add('hidden');
      }
    });

    // Copy URL
    const copyButton = document.getElementById('copy-url-button');
    copyButton?.addEventListener('click', async () => {
      const url = copyButton.getAttribute('data-url');
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);
      } catch {
        const input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }

      const original = copyButton.textContent;
      copyButton.textContent = 'Copied!';
      setTimeout(() => {
        copyButton.textContent = original;
        dropdown?.classList.add('hidden');
      }, 1500);
    });
  </script>
</BaseLayout>
